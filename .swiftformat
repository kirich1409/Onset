# SwiftFormat configuration — Onset (Swift 6, macOS 26.4)
# Run: swiftformat .          (auto-discovers this config — do NOT pass --config)
# CI:  swiftformat --lint .   (no --config: it changes rule resolution and emits false wrapAttributes errors)

--swiftversion 6.0
--minversion 0.54.0

# ── Indentation ──────────────────────────────────────────────────────────────
--indent 4
--tabwidth 4
--indentcase false
--xcodeindentation enabled
--indentstrings false

# ── Wrapping ─────────────────────────────────────────────────────────────────
--maxwidth 120
--wraparguments before-first
--wrapparameters before-first
--wrapcollections before-first
--wrapreturntype if-multiline
--wrapternary before-operators
--wrapconditions after-first
--wrapeffects preserve

# ── Braces / spacing ─────────────────────────────────────────────────────────
--allman false
--elseposition same-line
--guardelse auto
--emptybraces no-space
--trimwhitespace always

# ── Imports ───────────────────────────────────────────────────────────────────
--importgrouping alpha

# ── Declarations ──────────────────────────────────────────────────────────────
# Modifier order mirrors SwiftLint's preferred_modifier_order categories:
# override → isolation(nonisolated) → acl → lazy → final → required → convenience →
# typeMethods(static/class) → owned(weak/unowned) → indirect.
# Both tools now enforce the same idiomatic order (e.g. `private static let`).
--modifierorder override,nonisolated,private,fileprivate,internal,package,public,open,lazy,final,required,convenience,static,class,weak,unowned,indirect
--funcattributes prev-line
--typeattributes prev-line
--varattributes prev-line
--closurevoid remove
--self insert
--stripunusedargs closure-only
--redundanttype inferred
--nospaceoperators ...,..<

# ── String / comment ─────────────────────────────────────────────────────────
--commas always
--semicolons never
--trailingcommas always
--header strip

# ── Swift 6 specific ─────────────────────────────────────────────────────────
--asynccapturing false
--extensionacl on-declarations

# ── Excluded paths ────────────────────────────────────────────────────────────
--exclude Onset.xcodeproj,DerivedData,.build,swarm-report
